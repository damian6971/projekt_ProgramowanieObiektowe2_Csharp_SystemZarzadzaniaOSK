<Window x:Class="OskSystem.Views.DodajPojazdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dane Pojazdu" Width="350" Height="450" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Padding="20">
        <StackPanel>
            <TextBlock Text="Formularz Pojazdu" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="Kategoria Prawa Jazdy*"/>
            <ComboBox Height="30" ItemsSource="{Binding DostepneKategorie}" SelectedItem="{Binding WybranaKategoria}" Margin="0,5,0,10"/>

            <TextBlock Text="Marka*"/>
            <TextBox Height="30" Text="{Binding NowaMarka}" Margin="0,5,0,10"/>

            <TextBlock Text="Model*"/>
            <TextBox Height="30" Text="{Binding NowyModel}" Margin="0,5,0,10"/>

            <TextBlock Text="Numer Rejestracyjny*"/>
            <TextBox Height="30" Text="{Binding NowyRejestracja}" Margin="0,5,0,20"/>

            <Button Content="Zapisz" Height="40" Background="#8B5CF6" Foreground="White" Click="BtnZapisz_Click"/>
        </StackPanel>
    </Border>
</Window>