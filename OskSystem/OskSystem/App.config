<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <!-- Ciąg połączenia z bazą danych — zmień wartość bez rekompilacji projektu. -->
  <connectionStrings>
    <add name="OskBaza"
         connectionString="Server=(localdb)\mssqllocaldb;Database=OskBazaDanych;Trusted_Connection=True;TrustServerCertificate=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
</configuration>
